# Radio Stream Configuration
# IMPORTANT: Replace with your actual GKP Radio stream URL
EXPO_PUBLIC_STREAM_URL=https://stream.godkingdomprinciplesradio.com/live
EXPO_PUBLIC_AZURACAST_NOW_PLAYING_URL=https://stream.godkingdomprinciplesradio.com/api/nowplaying/gkp_radio
EXPO_PUBLIC_WORDPRESS_RADIO_STATUS_URL=https://godkingdomprinciplesradio.com/apis/wp-json/custom-api/v1/radio-status
EXPO_PUBLIC_LIVE_VIDEO_URL=
EXPO_PUBLIC_OWNCAST_URL=
EXPO_PUBLIC_LIVE_VIDEO_TITLE=Kingdom Principles Live Show
EXPO_PUBLIC_LIVE_VIDEO_THUMBNAIL_URL=

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_IMPORTER_EMAIL=importer@gkpradio.local

# WordPress REST API (podcasts, videos, merch store, checkout handoff)
# Required for Ministry Store — must include /apis if WordPress lives under /apis
EXPO_PUBLIC_WORDPRESS_API_BASE_URL=https://godkingdomprinciplesradio.com/apis/wp-json
# Optional: full URLs if /apis/wp-json returns HTML instead of JSON (nginx must route to WordPress)
# EXPO_PUBLIC_STORE_PRODUCTS_URL=https://your-site.com/apis/wp-json/custom-api/v1/products
# EXPO_PUBLIC_STORE_PREPARE_CART_URL=https://your-site.com/apis/wp-json/custom-api/v1/prepare-cart

# WordPress Import Source (scripts)
WORDPRESS_API_BASE_URL=https://godkingdomprinciplesradio.com/apis/wp-json

# Stripe Configuration (if needed)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_key_here

# API Configuration
EXPO_PUBLIC_API_URL=https://godkingdomprinciplesradio.com/api

# Optional: override giving page URL (must accept ?amount= query param)
# EXPO_PUBLIC_DONATE_URL=https://godkingdomprinciplesradio.com/donate

# Optional: Sentry crash reporting (EAS: set as secret for production builds)
# EXPO_PUBLIC_SENTRY_DSN=

# Optional: in-app support / safety report mailto targets
# EXPO_PUBLIC_HELP_DESK_EMAIL=helpdesk@gkpradio.com
# EXPO_PUBLIC_FEEDBACK_EMAIL=feedback@gkpradio.com

# Optional: Settings → Share & Rate (set when App Store listing is live)
# EXPO_PUBLIC_APP_SHARE_URL=https://gkpradio.com
# EXPO_PUBLIC_IOS_APP_STORE_ID=1234567890
# EXPO_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/id1234567890
# EXPO_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.gkpradio.mobile

# GKP Bible Games (website + shared leaderboard API — same as godkingdomprinciplesradio.com/games)
# EXPO_PUBLIC_GAMES_WEB_URL=https://godkingdomprinciplesradio.com/games
# EXPO_PUBLIC_GAMES_API_URL=https://godkingdomprinciplesradio.com/api/games

# Optional: Ministry Store browser fallback when WordPress product API is unavailable
# EXPO_PUBLIC_MERCH_STORE_WEB_URL=https://godkingdomprinciplesradio.com/shop
# EXPO_PUBLIC_STORE_PRODUCTS_URL=https://your-site.com/apis/wp-json/custom-api/v1/products
# EXPO_PUBLIC_STORE_PREPARE_CART_URL=https://your-site.com/apis/wp-json/custom-api/v1/prepare-cart
